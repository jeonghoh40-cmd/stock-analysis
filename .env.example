# ──────────────────────────────────────────────────────────────
# AI 주식 스크리닝 어드바이저 — 환경변수 설정
# 이 파일을 복사해서 .env 로 이름을 바꾼 뒤 값을 채워주세요.
#   Windows : copy .env.example .env
#   Mac/Linux: cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── [필수] Anthropic Claude API 키 ───────────────────────────
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-여기에입력

# ── [필수] 이메일 발송 설정 ───────────────────────────────────
# Microsoft 365 사용 시 (stic.co.kr 등 회사 메일):
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
EMAIL_USER=geunho@stic.co.kr
EMAIL_PASS=이메일_비밀번호_입력
EMAIL_FROM=geunho@stic.co.kr
EMAIL_TO=geunho@stic.co.kr
#
# Gmail 계정을 발신용으로 쓸 경우:
#   SMTP_SERVER=smtp.gmail.com
#   EMAIL_PASS= (Gmail 앱 비밀번호: 계정→보안→앱비밀번호 16자리)

# ── [선택] 카카오톡 나에게 보내기 ────────────────────────────
# 발급: https://developers.kakao.com → 내 애플리케이션 → 카카오 로그인
# 자세한 방법은 설정_가이드.txt 참고
KAKAO_TOKEN=카카오_액세스_토큰

# ── [선택] DART API — 국내 재무/공시 (없어도 기본 동작) ──────
# 발급: https://opendart.fss.or.kr (무료)
DART_API_KEY=여기에입력

# ── [선택] FRED API — 미국 금리 데이터 (없어도 기본 동작) ────
# 발급: https://fred.stlouisfed.org/docs/api/api_key.html (무료)
FRED_API_KEY=

# ── [선택] NewsAPI — 뉴스 강화 (없으면 RSS 자동 사용) ────────
# 발급: https://newsapi.org (무료 100건/일)
NEWS_API_KEY=

# ── [선택] 키움증권 OpenAPI+ — 국내 주문/시세 (없으면 시뮬레이션)
# 신청: https://www.kiwoom.com/h/customer/download/VOpenApiInfoView
# KIWOOM_ENV: dev(모의투자) / prod(실전투자)
KIWOOM_APP_KEY=키움_앱키_여기에입력
KIWOOM_SECRET_KEY=키움_시크릿키_여기에입력
KIWOOM_ENV=dev

# ── [선택] 한국투자증권 KIS API — 국내/미국 주문 (없으면 시뮬레이션)
# 신청: https://apiportal.koreainvestment.com
# KIS_ENV: vts(가상거래) / prod(실전거래)
KIS_APP_KEY=한국투자증권_앱키_여기에입력
KIS_SECRET_KEY=한국투자증권_시크릿키_여기에입력
KIS_ENV=vts
KIS_HTS_USER_ID=HTS_아이디_여기에입력